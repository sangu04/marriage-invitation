{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "serve-site",
      "type": "shell",
      "command": "py",
      "args": ["-m", "http.server", "8000", "--bind", "127.0.0.1"],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      },
      "problemMatcher": {
        "owner": "custom",
        "pattern": [
          {
            "regexp": ".*"
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Serving HTTP on",
          "endsPattern": "Serving HTTP on"
        }
      }
    }
  ]
}
